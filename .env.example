# Copy to .env and fill in. Never commit .env — it is gitignored.

# ── Wallets (node scripts/setup.js generates these) ───────────────────────────

# Seller receive wallet (public key) — shared by all seller personas in the demo.
# Fund at https://faucet.solana.com (GitHub sign-in; CLI/RPC airdrops are gated).
WALLET=

# Buyer keypair (base58 secret) — signs escrow deposit/release. Also fund it.
BUYER_KEYPAIR_B58=

SOLANA_RPC_URL=https://api.devnet.solana.com

# ── LLM brain (the agents' bidding + best-value selection) ────────────────────

# Anthropic by default:
ANTHROPIC_API_KEY=

# …or flip the WHOLE market to OpenAI (e.g. a sponsored Codex key) — no code change:
#   LLM_PROVIDER=openai
OPENAI_API_KEY=
LLM_PROVIDER=
LLM_MODEL=

# ── Market knobs ──────────────────────────────────────────────────────────────

BUYER_MAX_SOL=0.001       # budget cap per round
BUYER_SERVICE=coingecko   # what the buyer shops for (sellers self-select on it)
BID_WINDOW_MS=5000        # how long to collect competing bids each round
TRACE=                    # set to 1 to log coral_* calls + on-chain Explorer links

# ── Optional service API keys (the goods deliverService sells) ────────────────

HELIUS_API_KEY=           # faster devnet RPC (free at helius.dev)
JUPITER_API_KEY=          # higher Jupiter rate limits (free at jup.ag/developers)
NEWS_API_KEY=             # only for SERVICE=news (free at newsapi.org)

# ── Broker swarm (optional extension — see docs/SWARM.md) ─────────────────────
# Provision in one step: node scripts/setup.js --broker  (generates a 3rd wallet + sets these)
ENABLE_BROKER=            # set to 1 to route the buyer through a reselling broker
BROKER_KEYPAIR_B58=       # broker keypair (signs the upstream deposit/release) — fund it too
BROKER_WALLET=            # broker receive wallet (the buyer deposits here)
BROKER_MARGIN_SOL=0.0001  # spread the broker keeps (downstream price - upstream price)
